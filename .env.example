# Inception Registry Configuration

# Server settings
INCEPTION_HOST=0.0.0.0
INCEPTION_PORT=18080

# Database (SQLite default, Postgres for production)
INCEPTION_DATABASE_URL=sqlite:///data/inception.db
# For Postgres: INCEPTION_DATABASE_URL=postgres://inception:inception@postgres/inception

# Metrics
INCEPTION_METRICS_ENABLED=true
INCEPTION_METRICS_PORT=19090

# TLS (optional)
INCEPTION_TLS_ENABLED=false
# INCEPTION_TLS_CERT=/certs/cert.pem
# INCEPTION_TLS_KEY=/certs/key.pem
# INCEPTION_TLS_CA=/certs/ca.pem

# Tracing (optional)
INCEPTION_TRACING_ENABLED=false
# INCEPTION_JAEGER_ENDPOINT=http://jaeger:14268/api/traces

# Security (REQUIRED for token generation)
INCEPTION_ADMIN_TOKEN=your-secret-admin-token-here

# Log level
RUST_LOG=info
