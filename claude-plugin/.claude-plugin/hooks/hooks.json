{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "curl -s -X POST http://localhost:18081/hook/SessionStart -H 'Content-Type: application/json' -d '{\"source\": \"startup\"}' > /dev/null 2>&1 || true"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "curl -s -X POST http://localhost:18081/hook/UserPromptSubmit -H 'Content-Type: application/json' -d '{\"prompt\": \"'"'"'$(echo $CLaude_USER_PROMPT | sed \"s/'/'\\\"'\\\"'/g\")'"'"'\"}' > /dev/null 2>&1 || true"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "curl -s -X POST http://localhost:18081/hook/PreToolUse -H 'Content-Type: application/json' -d @- > /dev/null 2>&1 || true"
